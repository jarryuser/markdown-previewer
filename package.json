{
  "name": "markdown-previewer",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "mdp": "./dist/cli.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && vite build --config vite.cli.config.ts && chmod +x dist/cli.js",
    "build:cli": "vite build --config vite.cli.config.ts && chmod +x dist/cli.js",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "dependencies": {
    "highlight.js": "^11.9.0",
    "marked": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "gh-pages": "^6.1.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.4"
  }
}
